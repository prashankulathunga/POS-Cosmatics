generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum UserRole {
    ADMIN
    CASHIER
}

enum PaymentMethod {
    CASH
    CARD
}

enum SaleStatus {
    COMPLETED
}

enum StockMovementType {
    INITIAL
    SALE
    RETURN
    ADJUSTMENT_IN
    ADJUSTMENT_OUT
}

model User {
    id             String          @id @default(cuid())
    username       String          @unique
    email          String?         @unique
    fullName       String
    passwordHash   String
    role           UserRole
    isActive       Boolean         @default(true)
    lastLoginAt    DateTime?
    createdAt      DateTime        @default(now())
    updatedAt      DateTime        @updatedAt
    sales          Sale[]          @relation("CashierSales")
    returns        Return[]        @relation("CashierReturns")
    expenses       Expense[]       @relation("ExpenseCreator")
    stockMovements StockMovement[] @relation("StockMovementActor")

    @@index([role, isActive])
}

model Category {
    id          String    @id @default(cuid())
    name        String    @unique
    description String?
    isActive    Boolean   @default(true)
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    products    Product[]

    @@index([isActive, name])
}

model Product {
    id            String          @id @default(cuid())
    name          String
    barcode       String          @unique
    internalCode  String?         @unique
    categoryId    String?
    buyingPrice   Decimal         @db.Decimal(12, 2)
    sellingPrice  Decimal         @db.Decimal(12, 2)
    stockQuantity Int             @default(0)
    lowStockLimit Int             @default(5)
    isActive      Boolean         @default(true)
    createdAt     DateTime        @default(now())
    updatedAt     DateTime        @updatedAt
    category      Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
    saleItems     SaleItem[]
    stockMovement StockMovement[]
    returnItems   ReturnItem[]

    @@index([name])
    @@index([isActive, name])
    @@index([isActive, barcode])
    @@index([categoryId])
    @@index([stockQuantity])
    @@index([isActive, stockQuantity])
}

model Sale {
    id            String        @id @default(cuid())
    invoiceNumber String        @unique
    cashierId     String
    status        SaleStatus    @default(COMPLETED)
    subtotal      Decimal       @db.Decimal(12, 2)
    itemDiscount  Decimal       @default(0) @db.Decimal(12, 2)
    cartDiscount  Decimal       @default(0) @db.Decimal(12, 2)
    total         Decimal       @db.Decimal(12, 2)
    paidAmount    Decimal       @db.Decimal(12, 2)
    balance       Decimal       @default(0) @db.Decimal(12, 2)
    paymentMethod PaymentMethod
    note          String?
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt
    cashier       User          @relation("CashierSales", fields: [cashierId], references: [id], onDelete: Restrict)
    items         SaleItem[]
    payment       Payment?
    returns       Return[]

    @@index([cashierId, createdAt])
    @@index([createdAt])
    @@index([paymentMethod, createdAt])
}

model SaleItem {
    id                     String       @id @default(cuid())
    saleId                 String
    productId              String?
    productNameSnapshot    String
    productBarcodeSnapshot String
    buyingPriceSnapshot    Decimal      @db.Decimal(12, 2)
    sellingPriceSnapshot   Decimal      @db.Decimal(12, 2)
    quantity               Int
    lineSubtotal           Decimal      @db.Decimal(12, 2)
    discountAmount         Decimal      @default(0) @db.Decimal(12, 2)
    lineTotal              Decimal      @db.Decimal(12, 2)
    createdAt              DateTime     @default(now())
    sale                   Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
    product                Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
    returnItems            ReturnItem[]

    @@index([saleId])
    @@index([saleId, createdAt])
    @@index([productId])
}

model Payment {
    id        String        @id @default(cuid())
    saleId    String        @unique
    method    PaymentMethod
    amount    Decimal       @db.Decimal(12, 2)
    reference String?
    createdAt DateTime      @default(now())
    sale      Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model StockMovement {
    id             String            @id @default(cuid())
    productId      String
    type           StockMovementType
    quantityChange Int
    stockBefore    Int
    stockAfter     Int
    note           String?
    referenceId    String?
    referenceType  String?
    createdById    String?
    createdAt      DateTime          @default(now())
    product        Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
    createdBy      User?             @relation("StockMovementActor", fields: [createdById], references: [id], onDelete: SetNull)

    @@index([productId, createdAt])
    @@index([type, createdAt])
    @@index([createdAt])
}

model Return {
    id           String       @id @default(cuid())
    returnNumber String       @unique
    saleId       String
    cashierId    String
    reason       String?
    refundAmount Decimal      @db.Decimal(12, 2)
    createdAt    DateTime     @default(now())
    sale         Sale         @relation(fields: [saleId], references: [id], onDelete: Restrict)
    cashier      User         @relation("CashierReturns", fields: [cashierId], references: [id], onDelete: Restrict)
    items        ReturnItem[]

    @@index([saleId, createdAt])
    @@index([cashierId, createdAt])
    @@index([createdAt])
}

model ReturnItem {
    id                     String   @id @default(cuid())
    returnId               String
    saleItemId             String
    productId              String?
    quantity               Int
    unitPriceSnapshot      Decimal  @db.Decimal(12, 2)
    buyingPriceSnapshot    Decimal  @db.Decimal(12, 2)
    lineTotal              Decimal  @db.Decimal(12, 2)
    productNameSnapshot    String
    productBarcodeSnapshot String
    createdAt              DateTime @default(now())
    return                 Return   @relation(fields: [returnId], references: [id], onDelete: Cascade)
    saleItem               SaleItem @relation(fields: [saleItemId], references: [id], onDelete: Restrict)
    product                Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

    @@index([returnId])
    @@index([saleItemId])
}

model ExpenseCategory {
    id          String    @id @default(cuid())
    name        String    @unique
    description String?
    isActive    Boolean   @default(true)
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    expenses    Expense[]
}

model Expense {
    id          String           @id @default(cuid())
    title       String
    amount      Decimal          @db.Decimal(12, 2)
    note        String?
    expenseDate DateTime
    categoryId  String?
    createdById String?
    createdAt   DateTime         @default(now())
    updatedAt   DateTime         @updatedAt
    category    ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
    createdBy   User?            @relation("ExpenseCreator", fields: [createdById], references: [id], onDelete: SetNull)

    @@index([expenseDate])
    @@index([createdAt])
    @@index([categoryId, expenseDate])
}

model Settings {
    id             String   @id @default(cuid())
    shopName       String
    address        String
    phone          String
    receiptHeader  String?
    receiptFooter  String?
    currencyCode   String   @default("LKR")
    currencySymbol String   @default("Rs.")
    receiptCopies  Int      @default(1)
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt
}
